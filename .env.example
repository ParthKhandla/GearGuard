# =====================================================
# GearGuard Environment Variables
# =====================================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit actual .env file (only .env.example)
# =====================================================

# ─────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────
# Format: postgresql://username:password@host:port/database?sslmode=require
# For Neon: https://neon.tech (free tier available)
# For Local: postgresql://postgres:password@localhost:5432/gearguard
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# ─────────────────────────────────────────────────
# JWT Configuration
# ─────────────────────────────────────────────────
# Generate using: node -e "require('crypto').randomBytes(32).toString('hex')"
# Make these strong random strings for production!
ACCESS_TOKEN_SECRET=your-access-token-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-key-here-change-in-production
REFRESH_TOKEN_EXPIRY=10d

# ─────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────
# List frontend domains here (comma-separated for multiple)
# Development: http://localhost:5173
# Production: https://yourdomain.vercel.app
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────
# Email Configuration (Nodemailer - Gmail)
# ─────────────────────────────────────────────────
# Gmail requires App-Specific Password (not your regular password)
# To generate App Password:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Select Mail & Windows PC
#   3. Copy the generated password
#   4. Use it as EMAIL_PASS
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-specific-password

# ─────────────────────────────────────────────────
# Cloudinary Configuration (Image Storage)
# ─────────────────────────────────────────────────
# Sign up at: https://cloudinary.com (free tier available)
# Find credentials in Dashboard → Settings
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────────
# Logs (Optional)
# ─────────────────────────────────────────────────
LOG_LEVEL=info
# Options: error, warn, info, debug
